# VaultWatch Environment Variables
# Copy to .env and fill in your values

# Groq API (required)
#
# SECURITY (Critical Fix 7): the Groq key is SERVER-SIDE ONLY. It MUST live
# in this env var (GROQ_API_KEY) and NEVER in any VITE_* variable — Vite
# ships VITE_* values to the browser bundle, so VITE_GROQ_API_KEY would
# expose the key to anyone with devtools open.
#
# The dashboard never reads this key directly. All Groq calls go through
# the VaultWatch FastAPI proxy at /api/agent/* (in dev, Vite proxies
# /api/* -> http://localhost:8000/*). The FastAPI app reads GROQ_API_KEY
# server-side and injects it when calling https://api.groq.com.
#
# To get a key: sign in at https://console.groq.com and create one.
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API (optional — secondary AI provider for resilience)
# VaultWatch agents try Groq first, then OpenRouter if Groq fails,
# then heuristic fallback. Free models available at openrouter.ai.
# Sign up at https://openrouter.ai and create a key to enable this path.
OPENROUTER_API_KEY=your_openrouter_key_here_optional
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Casper Network
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_ACCOUNT_SECRET_KEY=your_secret_key_hex_here

# Casper Sidecar SSE
CASPER_SIDECAR_URL=http://127.0.0.1:18888/events/main

# CSPR.cloud API (required for live block/account data in the dashboard)
#
# SECURITY (Critical Fix 6): the previous CSPR.cloud key was hardcoded in
# dashboard/src/liveApi.js + several scripts and has been REVOKED. The new
# key MUST live in this env var only — never commit it to git.
#
# The dashboard never reads this key directly. Instead, it calls the
# VaultWatch FastAPI reverse proxy at /api/cspr_cloud/* (in dev, Vite
# proxies /api/* -> http://localhost:8000/*). The FastAPI app reads this
# env var server-side and injects `Authorization: Bearer $CSPR_CLOUD_API_KEY`
# when forwarding the request to https://api.testnet.cspr.cloud.
#
# Server-side scripts (broadcast_interactions.py, deploy_live.py, etc.)
# also read this env var directly — they run in a trusted environment and
# do not need the proxy.
#
# To get a key: sign in at https://cspr.cloud and create an access token
# in Account Settings.
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_API_KEY=your_rotated_cspr_cloud_key_here
# Optional: override the RPC endpoint used by /cspr_cloud/rpc (defaults to
# $CSPR_CLOUD_API_URL/rpc, which is https://api.testnet.cspr.cloud/rpc —
# the cspr.cloud JSON-RPC middleware). The public Casper testnet node
# (node.testnet.casper.network/rpc) does NOT require a key and is preferred
# for direct RPC when available.
# CSPR_CLOUD_RPC_URL=https://node.testnet.cspr.cloud/rpc
# Optional: proxy upstream timeout in seconds (default 15)
# CSPR_CLOUD_PROXY_TIMEOUT=15

# Deployed Contract Hashes (filled after deployment)
CONTRACT_AUDIT_TRAIL=
CONTRACT_RISK_ORACLE=
CONTRACT_SENTINEL_CREDIT=
CONTRACT_SENTINEL_REGISTRY=
CONTRACT_ALERT_LOG=
CONTRACT_AGENT_BEHAVIOR_INDEX=
CONTRACT_RISK_POLICY_MANAGER=
CONTRACT_SUBSCRIBER_VAULT=

# x402 Pay-per-query
X402_PAYMENT_AMOUNT=1000000  # 0.001 CSPR in motes

# OpenTelemetry (optional — stdout used if not set)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=vaultwatch

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
# In dev, leave unset — Vite proxies /api/* and /cspr_cloud/* to
# http://localhost:8000. In production, set this to the deployed API origin
# (e.g. https://api.vaultwatch.io).
# VITE_API_URL=https://api.vaultwatch.io
VITE_API_URL=http://localhost:8000
